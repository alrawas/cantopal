[
  {
    "id": "p139",
    "section": "section-13-dialogues",
    "cantonese": "nei5 hou2! hou2 noi6 mou5 gin3!",
    "english": "Hello! Long time no see!",
    "notes": "Speaker: A"
  },
  {
    "id": "p140",
    "section": "section-13-dialogues",
    "cantonese": "hai6 aa3! nei5 zeoi3 gan6 dim2 aa3?",
    "english": "Yeah! How are you lately?",
    "notes": "Speaker: B"
  },
  {
    "id": "p141",
    "section": "section-13-dialogues",
    "cantonese": "hou2 ho2, nei5 ne1?",
    "english": "I'm fine, and you?",
    "notes": "Speaker: A"
  },
  {
    "id": "p142",
    "section": "section-13-dialogues",
    "cantonese": "ngo5 dou1 hai6 hou2 ho2.",
    "english": "I'm also doing well.",
    "notes": "Speaker: B"
  },
  {
    "id": "p143",
    "section": "section-13-dialogues",
    "cantonese": "nei5 sik1 m4 sik1 gong2 jing1 man2?",
    "english": "Do you know how to speak English?",
    "notes": "Speaker: A"
  },
  {
    "id": "p144",
    "section": "section-13-dialogues",
    "cantonese": "siu2 siu2 laa1.",
    "english": "Just a little bit.",
    "notes": "Speaker: B"
  },
  {
    "id": "p145",
    "section": "section-13-dialogues",
    "cantonese": "m4 goi1, ci4 di1 gin3!",
    "english": "Thanks, see you later!",
    "notes": "Speaker: A"
  },
  {
    "id": "p146",
    "section": "section-13-dialogues",
    "cantonese": "baai1 baai3!",
    "english": "Bye-bye!",
    "notes": "Speaker: B"
  },
  {
    "id": "p147",
    "section": "section-13-dialogues",
    "cantonese": "m4 goi1! ngo5 soeng2 dim2 caan1.",
    "english": "Excuse me! I'd like to order.",
    "notes": "Speaker: A"
  },
  {
    "id": "p148",
    "section": "section-13-dialogues",
    "cantonese": "lei5 soeng2 sik6 me1 je5?",
    "english": "What would you like to eat?",
    "notes": "Speaker: B"
  },
  {
    "id": "p149",
    "section": "section-13-dialogues",
    "cantonese": "jat1 bui1 jit6 naai5 caa4, m4 goi1.",
    "english": "One cup of hot milk tea, please.",
    "notes": "Speaker: A"
  },
  {
    "id": "p150",
    "section": "section-13-dialogues",
    "cantonese": "siu2 tim1? siu2 bing1?",
    "english": "Less sugar? Less ice?",
    "notes": "Speaker: B"
  },
  {
    "id": "p151",
    "section": "section-13-dialogues",
    "cantonese": "m4 goi1, siu2 tim1, m4 jiu3 lau4.",
    "english": "Less sugar please, no MSG.",
    "notes": "Speaker: A"
  },
  {
    "id": "p152",
    "section": "section-13-dialogues",
    "cantonese": "hou2, hai6 m4 hai6 ji1 go3?",
    "english": "Okay, is that all?",
    "notes": "Speaker: B"
  },
  {
    "id": "p153",
    "section": "section-13-dialogues",
    "cantonese": "hai6 aa3, gei2 cin2 aa6?",
    "english": "Yes, how much is it?",
    "notes": "Speaker: A"
  },
  {
    "id": "p154",
    "section": "section-13-dialogues",
    "cantonese": "saam1 sap6 gau2 man1.",
    "english": "Thirty-nine dollars.",
    "notes": "Speaker: B"
  },
  {
    "id": "p155",
    "section": "section-13-dialogues",
    "cantonese": "m4 goi1, ngo5 daa2 baau1.",
    "english": "Thanks, I'll take it to go.",
    "notes": "Speaker: A"
  },
  {
    "id": "p156",
    "section": "section-13-dialogues",
    "cantonese": "m4 hou2 ji3 si1, hai2 bin1 dou6 hai6 MTR?",
    "english": "Excuse me, where is the MTR?",
    "notes": "Speaker: A"
  },
  {
    "id": "p157",
    "section": "section-13-dialogues",
    "cantonese": "zik1 zau2, sau2 zau2, hai2 go3 go3 zau6 hai6.",
    "english": "Go straight, turn left, it's over there.",
    "notes": "Speaker: B"
  },
  {
    "id": "p158",
    "section": "section-13-dialogues",
    "cantonese": "gei2 yun4 aa3?",
    "english": "How far is it?",
    "notes": "Speaker: A"
  },
  {
    "id": "p159",
    "section": "section-13-dialogues",
    "cantonese": "m4 hai6 hou2 yun4, saai3 zau2, 5 fan1 zung1.",
    "english": "Not very far, walk straight, 5 minutes.",
    "notes": "Speaker: B"
  },
  {
    "id": "p160",
    "section": "section-13-dialogues",
    "cantonese": "m4 goi1 saai3!",
    "english": "Thank you very much!",
    "notes": "Speaker: A"
  },
  {
    "id": "p161",
    "section": "section-13-dialogues",
    "cantonese": "m4 sai2 haak3 hei3, ci4 di1 gin3.",
    "english": "You're welcome, see you later.",
    "notes": "Speaker: B"
  },
  {
    "id": "p162",
    "section": "section-13-dialogues",
    "cantonese": "m4 goi1, ji1 go3 gei2 cin2 aa6?",
    "english": "Excuse me, how much is this one?",
    "notes": "Speaker: A"
  },
  {
    "id": "p163",
    "section": "section-13-dialogues",
    "cantonese": "saam1 baak3 man1.",
    "english": "Three hundred dollars.",
    "notes": "Speaker: B"
  },
  {
    "id": "p164",
    "section": "section-13-dialogues",
    "cantonese": "waa6, gam3 gwai3! peng4 di1 laa1!",
    "english": "Wow, that's expensive! Cheaper please!",
    "notes": "Speaker: A"
  },
  {
    "id": "p165",
    "section": "section-13-dialogues",
    "cantonese": "m4 ho2 ji3 si1, ji1 hai6 zeoi3 peng4 gaa3 laa3.",
    "english": "Sorry, this is the cheapest already.",
    "notes": "Speaker: B"
  },
  {
    "id": "p166",
    "section": "section-13-dialogues",
    "cantonese": "jau5 mou5 zit3 aa6?",
    "english": "Are there any discounts?",
    "notes": "Speaker: A"
  },
  {
    "id": "p167",
    "section": "section-13-dialogues",
    "cantonese": "m4 goi1, m4 ho2 ji3 si1, m4 hai6 hou2 ji3 si1.",
    "english": "Sorry, I'm afraid not.",
    "notes": "Speaker: B"
  },
  {
    "id": "p168",
    "section": "section-13-dialogues",
    "cantonese": "m4 goi1 saai3, ngo5 ling6 waan2 gau3 sin1.",
    "english": "Thank you, I'll look around first.",
    "notes": "Speaker: A"
  },
  {
    "id": "p169",
    "section": "section-13-dialogues",
    "cantonese": "m4 goi1, gau3 ming6 aa3! ngo5 sat1 zo2 aa3!",
    "english": "Help! I'm lost!",
    "notes": "Speaker: A"
  },
  {
    "id": "p170",
    "section": "section-13-dialogues",
    "cantonese": "dim2 gaai2? nei5 hai2 bin1 dou6 aa3?",
    "english": "Why? Where are you?",
    "notes": "Speaker: B"
  },
  {
    "id": "p171",
    "section": "section-13-dialogues",
    "cantonese": "ngo5 m4 sik1 gong2 jing1 man2.",
    "english": "I don't speak English.",
    "notes": "Speaker: A"
  },
  {
    "id": "p172",
    "section": "section-13-dialogues",
    "cantonese": "m4 gan2, hai2 bin1 dou6 nei5 zeoi3 gan6?",
    "english": "Don't worry, where are you right now?",
    "notes": "Speaker: B"
  },
  {
    "id": "p173",
    "section": "section-13-dialogues",
    "cantonese": "ngo5 hai2 ding3 nei6 gung1 jyun2 gan1 ceng4.",
    "english": "I'm near the MTR station.",
    "notes": "Speaker: A"
  },
  {
    "id": "p174",
    "section": "section-13-dialogues",
    "cantonese": "m4 goi1, deng2 deng2, ngo5 lai4 wan2 nei5.",
    "english": "Wait a moment, I'll come find you.",
    "notes": "Speaker: B"
  },
  {
    "id": "p175",
    "section": "section-13-dialogues",
    "cantonese": "do1 ze6 saai3!",
    "english": "Thank you so much!",
    "notes": "Speaker: A"
  },
  {
    "id": "p176",
    "section": "section-13-dialogues",
    "cantonese": "nei5 soeng2 jam2 me1 je5?",
    "english": "What would you like to drink?",
    "notes": "Speaker: A"
  },
  {
    "id": "p177",
    "section": "section-13-dialogues",
    "cantonese": "jat1 bui1 beng2 caa4, siu2 tim1, m4 goi1.",
    "english": "One iced milk tea, less sugar please.",
    "notes": "Speaker: B"
  },
  {
    "id": "p178",
    "section": "section-13-dialogues",
    "cantonese": "ngo5 jiu3 jat1 bui1 kei4 ze2 lai4.",
    "english": "I'll have one lemon tea.",
    "notes": "Speaker: A"
  },
  {
    "id": "p179",
    "section": "section-13-dialogues",
    "cantonese": "hou2 ci4 aa3! hai2 ni1 dou6 hou2 leng3!",
    "english": "Awesome! It's beautiful here!",
    "notes": "Speaker: B"
  },
  {
    "id": "p180",
    "section": "section-13-dialogues",
    "cantonese": "hai6 aa3, hou2 noi6 mou5 gin3?",
    "english": "Yeah, long time no see?",
    "notes": "Speaker: A"
  },
  {
    "id": "p181",
    "section": "section-13-dialogues",
    "cantonese": "hai6 aa3, ne1 ci3 ngo5 maai4 daan1.",
    "english": "Yeah, this time I'll pay.",
    "notes": "Speaker: B"
  },
  {
    "id": "p182",
    "section": "section-13-dialogues",
    "cantonese": "m4 goi1 saai3, haa3 ci3 gin3!",
    "english": "Thank you so much, see you next time!",
    "notes": "Speaker: A"
  }
]